# ---------------------------------------------------------------------------
# KESHV OS — environment variables
# Copy to .env.local and fill in from your Supabase project settings.
# ---------------------------------------------------------------------------

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only key — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Prisma → Supabase Postgres (Project Settings → Database)
# DATABASE_URL: transaction pooler (port 6543, pgbouncer)
# DIRECT_URL:   direct connection (port 5432) — used for migrations
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"
